# Generated defaults; project settings below take precedence.
import %workspace%/tools/preset.bazelrc

common --@com_google_protobuf//bazel/toolchains:prefer_prebuilt_protoc=true
common --@com_google_protobuf//bazel/flags:experimental_proto_descriptor_sets_include_source_info=true
common:windows --host_platform=//platforms:local_windows_msvc

# Optional local overrides, intentionally excluded from version control.
try-import %workspace%/user.bazelrc
