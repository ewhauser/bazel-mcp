---
const withBase = (pathname: string) =>
  `${import.meta.env.BASE_URL}${pathname.replace(/^\/+/, '')}`;

const noisyLines = [
  ['INFO', 'Analyzed target //app:server (84 packages loaded)'],
  ['SUB', '[412 / 638] Compiling services/cache/cache.cc'],
  ['SUB', '[529 / 638] Compiling services/api/router.cc'],
  ['WARN', 'warning: option --remote_download_toplevel changed'],
  ['ERR', 'services/api/router.cc:148:17: error: no matching function'],
  ['SUB', 'Target //app:server failed to build'],
];

const tools = [
  {
    name: 'bazel.run',
    tag: 'EXECUTE',
    description:
      'Run an allowed Bazel or configured Aspect command and receive a bounded, root-cause-first result.',
    detail: 'Build · test · lint · query',
  },
  {
    name: 'bazel.inspect',
    tag: 'EVIDENCE',
    description:
      'Retrieve only the diagnostics, test logs, artifacts, or query results needed next.',
    detail: 'Filtered · paginated · retained locally',
  },
  {
    name: 'bazel.cancel',
    tag: 'CONTROL',
    description:
      'Cancel a queued or running invocation through the same durable lifecycle.',
    detail: 'Queued · running · task-aware',
  },
];
---

<main class="landing">
  <section class="hero" aria-labelledby="hero-title">
    <div class="hero-copy">
      <p class="eyebrow"><span aria-hidden="true"></span> Local MCP for Bazel</p>
      <h1 id="hero-title">
        Give Bazel output<br />
        <em>a context budget.</em>
      </h1>
      <p class="lede">
        Run Bazel from coding agents without pouring build logs into the model.
        Get the root cause first and keep the complete evidence available locally.
      </p>
      <div class="hero-actions">
        <a class="button primary" href={withBase('getting-started/')}>Get started</a>
        <a class="button secondary" href="https://github.com/ewhauser/bazel-mcp">
          View on GitHub <span aria-hidden="true">↗</span>
        </a>
      </div>
      <div class="install" aria-label="Homebrew installation command">
        <span class="prompt" aria-hidden="true">$</span>
        <code>brew install ewhauser/tap/bazel-mcp</code>
        <button type="button" data-copy="brew install ewhauser/tap/bazel-mcp">
          <span class="copy-label">Copy</span>
        </button>
      </div>
    </div>

    <div class="compression" aria-label="Bazel output compressed into an actionable result">
      <div class="stage-label">
        <span>Live evidence pipeline</span>
        <span class="status"><i aria-hidden="true"></i> local only</span>
      </div>
      <div class="pipeline">
        <div class="terminal noise" aria-label="Unbounded Bazel output">
          <div class="terminal-bar">
            <div class="dots" aria-hidden="true"><i></i><i></i><i></i></div>
            <span>bazel test //...</span>
            <span>482 KB</span>
          </div>
          <div class="terminal-body">
            {noisyLines.map(([kind, line], index) => (
              <p class:list={{ error: kind === 'ERR', muted: kind === 'SUB' }} style={`--line:${index}`}>
                <span>{kind}</span>{line}
              </p>
            ))}
          </div>
        </div>

        <div class="funnel" aria-hidden="true">
          <span></span><span></span><span></span>
          <strong>reduce</strong>
        </div>

        <div class="terminal result" aria-label="Bounded bazel.run result">
          <div class="terminal-bar">
            <div class="result-mark" aria-hidden="true">✓</div>
            <span>bazel.run</span>
            <span>1.7 KB</span>
          </div>
          <div class="result-body">
            <p><span>state</span><strong>failed</strong></p>
            <p><span>target</span><code>//app:server</code></p>
            <div class="diagnostic">
              <span>ROOT CAUSE</span>
              <strong>no matching function</strong>
              <code>services/api/router.cc:148:17</code>
            </div>
            <p class="more"><span>more_available</span><strong>true</strong></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="proof" aria-label="Measured performance">
    <a href={withBase('reference/generated/benchmarks/')}>
      <strong>89.73%</strong>
      <span>less model context</span>
      <small>latest deterministic run</small>
    </a>
    <a href={withBase('reference/generated/benchmarks/')}>
      <strong>96.43%</strong>
      <span>fewer visible bytes</span>
      <small>against default shell</small>
    </a>
    <a href={withBase('reference/generated/benchmarks/')}>
      <strong>0.00%</strong>
      <span>median Bazel overhead</span>
      <small>paired wall time</small>
    </a>
    <a href={withBase('tools/')}>
      <strong>3</strong>
      <span>focused MCP tools</span>
      <small>run · inspect · cancel</small>
    </a>
  </section>

  <section class="section tools-section" aria-labelledby="tools-title">
    <div class="section-heading">
      <p class="kicker">A deliberately small interface</p>
      <h2 id="tools-title">Three tools. The whole evidence loop.</h2>
      <p>
        The public surface stays easy for agents to understand while the server handles
        process isolation, reduction, storage, and lifecycle details locally.
      </p>
    </div>
    <div class="tool-grid">
      {tools.map((tool, index) => (
        <article class="tool-card">
          <div class="tool-topline">
            <span>0{index + 1}</span>
            <small>{tool.tag}</small>
          </div>
          <h3><code>{tool.name}</code></h3>
          <p>{tool.description}</p>
          <footer>{tool.detail}</footer>
        </article>
      ))}
    </div>
  </section>

  <section class="section evidence-section" aria-labelledby="evidence-title">
    <div class="evidence-copy">
      <p class="kicker">Compact does not mean lossy</p>
      <h2 id="evidence-title">Start narrow. Inspect with intent.</h2>
      <p>
        Every result carries an invocation ID. If an agent needs more detail, it asks for
        a filtered, byte-bounded view instead of replaying the entire log into context.
      </p>
      <a class="text-link" href={withBase('concepts/how-it-works/')}>
        Follow the evidence lifecycle <span aria-hidden="true">→</span>
      </a>
    </div>
    <div class="sequence" aria-label="Run, inspect, and solve sequence">
      <div>
        <span>01</span>
        <strong>Run</strong>
        <p>Root cause and invocation ID arrive inside the response budget.</p>
      </div>
      <div>
        <span>02</span>
        <strong>Inspect</strong>
        <p>Request a diagnostic, test log, artifact, query result, or raw log page.</p>
      </div>
      <div>
        <span>03</span>
        <strong>Solve</strong>
        <p>Fix the code with evidence—not noise—occupying the model context.</p>
      </div>
    </div>
  </section>

</main>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((button) => {
    button.addEventListener('click', async () => {
      const value = button.dataset.copy;
      if (!value) return;

      await navigator.clipboard.writeText(value);
      const label = button.querySelector('.copy-label');
      if (!label) return;

      label.textContent = 'Copied';
      window.setTimeout(() => {
        label.textContent = 'Copy';
      }, 1600);
    });
  });
</script>

<style>
  .landing {
    --mint: #7cf5b6;
    --mint-bright: #b4ffd5;
    --cyan: #68d9ff;
    --ink: #07100d;
    --panel: rgba(10, 24, 19, 0.82);
    --line: rgba(166, 255, 208, 0.15);
    color: #e9fff3;
    margin-top: -1.5rem;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(34rem, 1.1fr);
    gap: clamp(3rem, 7vw, 7rem);
    align-items: center;
    min-height: calc(100vh - 6rem);
    padding: clamp(5rem, 10vw, 9rem) max(1.25rem, calc((100vw - 86rem) / 2));
    position: relative;
  }

  .hero::before {
    background:
      radial-gradient(circle at 72% 42%, rgba(65, 235, 151, 0.12), transparent 26rem),
      linear-gradient(rgba(124, 245, 182, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(124, 245, 182, 0.035) 1px, transparent 1px);
    background-size: auto, 4rem 4rem, 4rem 4rem;
    content: '';
    inset: 0;
    mask-image: linear-gradient(to bottom, black 70%, transparent);
    pointer-events: none;
    position: absolute;
    z-index: -1;
  }

  .hero-copy { max-width: 43rem; }

  .eyebrow,
  .kicker {
    color: var(--mint);
    font-family: var(--sl-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    margin: 0 0 1.4rem;
    text-transform: uppercase;
  }

  .eyebrow { align-items: center; display: flex; gap: 0.7rem; }
  .eyebrow span {
    background: var(--mint);
    border-radius: 50%;
    box-shadow: 0 0 0 0.35rem rgba(124, 245, 182, 0.1), 0 0 1rem var(--mint);
    height: 0.42rem;
    width: 0.42rem;
  }

  h1 {
    color: #f3fff8;
    font-size: clamp(3.5rem, 7vw, 7.2rem);
    font-weight: 680;
    letter-spacing: -0.065em;
    line-height: 0.9;
    margin: 0;
    max-width: 10ch;
  }

  h1 em {
    color: var(--mint);
    font-style: normal;
    text-shadow: 0 0 2.5rem rgba(124, 245, 182, 0.2);
  }

  .lede {
    color: #adc4b7;
    font-size: clamp(1.05rem, 1.6vw, 1.3rem);
    line-height: 1.65;
    margin: 2rem 0 0;
    max-width: 38rem;
  }

  .hero-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; margin-top: 2rem; }

  .button {
    align-items: center;
    border: 1px solid transparent;
    border-radius: 0.6rem;
    display: inline-flex;
    font-family: var(--sl-font-mono);
    font-size: 0.82rem;
    font-weight: 750;
    gap: 0.5rem;
    justify-content: center;
    letter-spacing: 0.02em;
    padding: 0.8rem 1.15rem;
    text-decoration: none;
    transition: transform 150ms ease, border-color 150ms ease, background 150ms ease;
  }

  .button:hover { transform: translateY(-2px); }
  .button.primary { background: var(--mint); color: #04110a; }
  .button.primary:hover { background: var(--mint-bright); }
  .button.secondary { background: rgba(255,255,255,0.025); border-color: var(--line); color: #dff8e9; }
  .button.secondary:hover { border-color: rgba(124,245,182,0.45); }

  .install {
    align-items: center;
    background: rgba(4, 13, 9, 0.72);
    border: 1px solid var(--line);
    border-radius: 0.65rem;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    margin-top: 1rem;
    max-width: 36rem;
    overflow: hidden;
  }

  .install .prompt { color: var(--mint); font-family: var(--sl-font-mono); padding-left: 1rem; }
  .install code {
    background: transparent;
    color: #c8ded1;
    font-size: 0.77rem;
    overflow-x: auto;
    padding: 0.85rem 0.75rem;
    white-space: nowrap;
  }
  .install button {
    align-self: stretch;
    background: rgba(124,245,182,0.06);
    border: 0;
    border-left: 1px solid var(--line);
    color: var(--mint);
    cursor: pointer;
    font-family: var(--sl-font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0 0.9rem;
  }

  .compression {
    background: linear-gradient(145deg, rgba(14, 33, 25, 0.78), rgba(5, 14, 10, 0.88));
    border: 1px solid rgba(124, 245, 182, 0.18);
    border-radius: 1rem;
    box-shadow: 0 2rem 8rem rgba(0,0,0,0.28), inset 0 1px rgba(255,255,255,0.035);
    min-width: 0;
    padding: 1rem;
    position: relative;
  }

  .compression::after {
    border: 1px solid rgba(104,217,255,0.2);
    border-radius: inherit;
    content: '';
    inset: -0.45rem 0.55rem 0.55rem -0.45rem;
    pointer-events: none;
    position: absolute;
    z-index: -1;
  }

  .stage-label,
  .terminal-bar,
  .tool-topline {
    align-items: center;
    display: flex;
    justify-content: space-between;
  }

  .stage-label {
    color: #7f9b8d;
    font-family: var(--sl-font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    padding: 0 0.15rem 0.75rem;
    text-transform: uppercase;
  }
  .status { align-items: center; display: flex; gap: 0.45rem; }
  .status i { background: var(--mint); border-radius: 50%; height: 0.35rem; width: 0.35rem; }

  .pipeline {
    display: grid;
    gap: 0.65rem;
    grid-template-columns: minmax(0, 1.05fr) 3.6rem minmax(0, 0.95fr);
    align-items: stretch;
  }

  .terminal {
    background: #06100c;
    border: 1px solid rgba(195,255,221,0.12);
    border-radius: 0.7rem;
    min-width: 0;
    overflow: hidden;
  }

  .terminal-bar {
    background: rgba(255,255,255,0.025);
    border-bottom: 1px solid rgba(195,255,221,0.09);
    color: #617b6c;
    font-family: var(--sl-font-mono);
    font-size: 0.58rem;
    height: 2.25rem;
    padding: 0 0.7rem;
  }
  .terminal-bar > span:nth-child(2) { color: #a6b9ae; }
  .dots { display: flex; gap: 0.28rem; }
  .dots i { background: #2d4437; border-radius: 50%; height: 0.36rem; width: 0.36rem; }

  .terminal-body { height: 21rem; overflow: hidden; padding: 0.8rem; position: relative; }
  .terminal-body::after {
    background: linear-gradient(transparent, #06100c 88%);
    content: '';
    inset: 0;
    pointer-events: none;
    position: absolute;
  }
  .terminal-body p {
    animation: log-pulse 5s calc(var(--line) * 0.24s) ease-in-out infinite;
    color: #92a89b;
    display: grid;
    font-family: var(--sl-font-mono);
    font-size: 0.58rem;
    gap: 0.45rem;
    grid-template-columns: 2.5rem 1fr;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }
  .terminal-body p span { color: #587265; font-size: 0.52rem; }
  .terminal-body p.error { color: #ff9e9e; }
  .terminal-body p.error span { color: #ff7171; }
  .terminal-body p.muted { opacity: 0.64; }

  .funnel { align-items: center; display: flex; flex-direction: column; justify-content: center; gap: 0.4rem; }
  .funnel span {
    animation: packet 2.8s ease-in-out infinite;
    background: linear-gradient(90deg, transparent, var(--mint), transparent);
    height: 1px;
    opacity: 0.45;
    width: 100%;
  }
  .funnel span:nth-child(2) { animation-delay: 0.28s; width: 70%; }
  .funnel span:nth-child(3) { animation-delay: 0.56s; width: 38%; }
  .funnel strong {
    color: var(--mint);
    font-family: var(--sl-font-mono);
    font-size: 0.52rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    margin-top: 0.35rem;
    text-transform: uppercase;
  }

  .result { border-color: rgba(124,245,182,0.28); }
  .result-mark {
    align-items: center;
    background: rgba(124,245,182,0.12);
    border-radius: 50%;
    color: var(--mint);
    display: flex;
    height: 1.1rem;
    justify-content: center;
    width: 1.1rem;
  }
  .result-body { padding: 0.8rem; }
  .result-body > p {
    display: grid;
    font-family: var(--sl-font-mono);
    font-size: 0.63rem;
    grid-template-columns: 5.8rem minmax(0, 1fr);
    margin: 0 0 0.65rem;
  }
  .result-body p span { color: #5e7869; }
  .result-body p strong { color: #ff9292; font-weight: 650; }
  .result-body p code { background: transparent; color: #bdd3c6; padding: 0; }
  .diagnostic {
    background: rgba(255, 113, 113, 0.055);
    border: 1px solid rgba(255, 125, 125, 0.16);
    border-left: 2px solid #ff7d7d;
    border-radius: 0.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.42rem;
    margin: 0.9rem 0;
    padding: 0.75rem;
  }
  .diagnostic span { color: #ff8f8f; font-family: var(--sl-font-mono); font-size: 0.48rem; letter-spacing: 0.1em; }
  .diagnostic strong { color: #ffd3d3; font-family: var(--sl-font-mono); font-size: 0.65rem; }
  .diagnostic code { background: transparent; color: #9db3a6; font-size: 0.53rem; padding: 0; }
  .result-body .more strong { color: var(--mint); }

  .proof {
    border-bottom: 1px solid var(--line);
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 86rem;
  }
  .proof a {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: 2rem clamp(1rem, 2vw, 2rem);
    text-decoration: none;
  }
  .proof a + a { border-left: 1px solid var(--line); }
  .proof strong { color: var(--mint); font-family: var(--sl-font-mono); font-size: clamp(1.7rem, 3vw, 2.8rem); letter-spacing: -0.06em; }
  .proof span { color: #daeae0; font-size: 0.8rem; font-weight: 650; margin-top: 0.4rem; }
  .proof small { color: #607a6b; font-family: var(--sl-font-mono); font-size: 0.58rem; margin-top: 0.25rem; text-transform: uppercase; }

  .section {
    margin: 0 auto;
    max-width: 86rem;
    padding: clamp(5rem, 10vw, 9rem) 1.25rem;
  }
  .section-heading { max-width: 48rem; }
  .section h2 {
    color: #effff5;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    letter-spacing: -0.045em;
    line-height: 1.02;
    margin: 0;
  }
  .section-heading > p:last-child,
  .evidence-copy > p:not(.kicker) { color: #879f91; font-size: 1rem; line-height: 1.7; margin-top: 1.35rem; }

  .tool-grid { display: grid; gap: 1rem; grid-template-columns: repeat(3, 1fr); margin-top: 3.5rem; }
  .tool-card {
    background: linear-gradient(150deg, rgba(13,31,23,0.74), rgba(6,16,11,0.74));
    border: 1px solid var(--line);
    border-radius: 0.8rem;
    display: flex;
    flex-direction: column;
    min-height: 20rem;
    overflow: hidden;
    padding: 1.25rem;
    position: relative;
  }
  .tool-card::after {
    background: radial-gradient(circle, rgba(124,245,182,0.12), transparent 70%);
    content: '';
    height: 12rem;
    position: absolute;
    right: -5rem;
    top: -5rem;
    width: 12rem;
  }
  .tool-topline { border-bottom: 1px solid var(--line); padding-bottom: 1rem; }
  .tool-topline span,
  .tool-topline small { color: #5d7668; font-family: var(--sl-font-mono); font-size: 0.58rem; letter-spacing: 0.09em; }
  .tool-topline small { color: var(--mint); }
  .tool-card h3 { font-size: clamp(1.4rem, 2.5vw, 2rem); margin: 2.4rem 0 1rem; }
  .tool-card h3 code { background: transparent; color: #e9fff2; padding: 0; }
  .tool-card > p { color: #8da596; line-height: 1.65; margin: 0; }
  .tool-card footer { color: #60796a; font-family: var(--sl-font-mono); font-size: 0.62rem; margin-top: auto; padding-top: 2rem; }

  .evidence-section {
    align-items: start;
    border-top: 1px solid var(--line);
    display: grid;
    gap: clamp(3rem, 9vw, 9rem);
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
  }
  .text-link { color: var(--mint); display: inline-block; font-family: var(--sl-font-mono); font-size: 0.78rem; font-weight: 700; margin-top: 1rem; text-decoration: none; }
  .sequence { border-top: 1px solid var(--line); }
  .sequence > div {
    display: grid;
    gap: 1.2rem;
    grid-template-columns: 2.5rem 6rem minmax(0, 1fr);
    padding: 1.45rem 0;
  }
  .sequence > div + div { border-top: 1px solid var(--line); }
  .sequence span { color: var(--mint); font-family: var(--sl-font-mono); font-size: 0.63rem; }
  .sequence strong { color: #e3f5e9; font-size: 0.9rem; }
  .sequence p { color: #789183; font-size: 0.82rem; line-height: 1.55; margin: 0; }

  @keyframes log-pulse {
    0%, 80%, 100% { transform: translateY(0); opacity: 0.75; }
    12% { transform: translateY(-0.18rem); opacity: 1; }
  }
  @keyframes packet {
    0%, 100% { opacity: 0.16; transform: scaleX(0.45); }
    50% { opacity: 0.85; transform: scaleX(1); }
  }

  @media (max-width: 1100px) {
    .hero { grid-template-columns: 1fr; min-height: auto; }
    .hero-copy { max-width: 48rem; }
    .compression { max-width: 58rem; }
  }

  @media (max-width: 760px) {
    .landing { margin-top: -0.5rem; }
    .hero { padding-top: 4rem; }
    h1 { font-size: clamp(3rem, 16vw, 5rem); }
    .pipeline { grid-template-columns: 1fr; }
    .funnel { flex-direction: row; height: 2.8rem; transform: rotate(90deg); }
    .funnel span { width: 2rem; }
    .funnel strong { display: none; }
    .terminal-body { height: 15rem; }
    .proof { grid-template-columns: repeat(2, 1fr); }
    .proof a:nth-child(3) { border-left: 0; border-top: 1px solid var(--line); }
    .proof a:nth-child(4) { border-top: 1px solid var(--line); }
    .tool-grid,
    .evidence-section { grid-template-columns: 1fr; }
    .tool-card { min-height: 17rem; }
  }

  @media (max-width: 480px) {
    .hero-actions .button { width: 100%; }
    .install code { font-size: 0.66rem; }
    .proof { grid-template-columns: 1fr; }
    .proof a + a { border-left: 0; border-top: 1px solid var(--line); }
    .sequence > div { grid-template-columns: 2rem 1fr; }
    .sequence p { grid-column: 2; }
  }

  @media (prefers-reduced-motion: reduce) {
    .terminal-body p,
    .funnel span { animation: none; }
    .button { transition: none; }
  }
</style>
